---
import BaseLayout from '../layouts/BaseLayout.astro';

// Required env vars (create a .env file at project root):
// PUBLIC_PADDLE_TOKEN=your_client_side_token
// PUBLIC_PADDLE_PRICE_ID=your_price_id
const paddleToken = import.meta.env.PUBLIC_PADDLE_TOKEN;
const paddlePriceId = import.meta.env.PUBLIC_PADDLE_PRICE_ID;
---

<BaseLayout title="AI that checks its own work." canonical="https://wazear.space">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #0d0d0c;
    --bg-raised:    #131312;
    --bg-hover:     #191917;
    --border:       #232320;
    --text:         #e4e4dc;
    --muted:        #62625c;
    --muted-light:  #8a8a82;
    --accent:       #c8a847;
    --accent-dim:   #7a6525;
    --mono-bg:      #1c1c1a;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  /* Grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.022;
    pointer-events: none;
    z-index: 9999;
  }

  .mono { font-family: 'Fragment Mono', monospace; }
  .serif { font-family: 'Instrument Serif', serif; }

  .container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ─── NAV ─── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 13, 12, 0.96);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 32px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .nav-logo {
    font-family: 'Fragment Mono', monospace;
    font-size: 14px;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
  }

  .nav-links li { display: flex; align-items: center; }

  .nav-links a {
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    padding: 4px 16px;
    transition: color 150ms;
  }

  .nav-links a:hover { color: var(--text); }

  .nav-links .sep {
    color: var(--border);
    font-family: 'Fragment Mono', monospace;
    font-size: 11px;
    user-select: none;
  }

  .nav-cta {
    background: var(--accent);
    color: var(--bg) !important;
    font-weight: 500;
    padding: 7px 18px !important;
    border-radius: 2px;
    font-size: 13px !important;
    transition: background 150ms !important;
    flex-shrink: 0;
  }

  .nav-cta:hover { background: var(--accent-dim) !important; color: var(--text) !important; }

  /* ─── HERO ─── */
  #hero {
    min-height: calc(100vh - 56px);
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 64px;
    align-items: center;
    padding: 80px 32px 80px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .hero-label {
    font-family: 'Fragment Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 400ms ease forwards;
    animation-delay: 0ms;
  }

  .hero-h1 {
    font-family: 'Instrument Serif', serif;
    font-size: 62px;
    line-height: 1.04;
    font-weight: 400;
    color: var(--text);
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 400ms ease forwards;
    animation-delay: 80ms;
  }

  .hero-sub {
    font-size: 17px;
    color: var(--muted-light);
    max-width: 500px;
    margin-top: 20px;
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 400ms ease forwards;
    animation-delay: 160ms;
  }

  .hero-price {
    margin-top: 36px;
    font-size: 14px;
    color: var(--muted);
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 400ms ease forwards;
    animation-delay: 240ms;
  }

  .hero-price .price-tag {
    font-family: 'Fragment Mono', monospace;
    color: var(--accent);
    font-size: 16px;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    margin-top: 28px;
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 400ms ease forwards;
    animation-delay: 320ms;
  }

  .hero-early-access {
    font-size: 11px;
    color: var(--muted);
    margin-top: 12px;
    letter-spacing: 0.03em;
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 400ms ease forwards;
    animation-delay: 280ms;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    padding: 13px 28px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 150ms;
  }

  .btn-primary:hover { background: #b8952f; }

  .hero-meta {
    font-family: 'Fragment Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    line-height: 1.8;
  }

  /* ─── PIPELINE GRAPHIC ─── */
  .pipeline-graphic {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .pipeline-svg {
    width: 100%;
    max-width: 340px;
    opacity: 0;
    animation: fadeUp 600ms ease forwards;
    animation-delay: 400ms;
  }

  .node-rect {
    fill: var(--bg-raised);
    stroke: var(--border);
    stroke-width: 1;
    transition: stroke 200ms;
  }

  .node-rect:hover { stroke: var(--accent-dim); }

  .node-label {
    font-family: 'Fragment Mono', monospace;
    font-size: 9px;
    fill: var(--muted);
    dominant-baseline: middle;
  }

  .node-label.reviewer { fill: #3e3e38; }

  .connector {
    stroke: var(--border);
    stroke-width: 1;
    fill: none;
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: drawLine 1.2s ease forwards;
  }

  .connector-review {
    stroke: var(--mono-bg);
    stroke-width: 1;
    fill: none;
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
    animation: drawLine 0.6s ease forwards;
  }

  .pulse-line {
    stroke: var(--border);
    stroke-width: 1;
    fill: none;
    animation: pulse 3s ease-in-out infinite alternate;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  @keyframes pulse {
    from { opacity: 0.2; }
    to   { opacity: 0.7; }
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── SECTIONS SHARED ─── */
  section {
    border-top: 1px solid var(--border);
    padding: 100px 0;
  }

  .section-label {
    font-family: 'Fragment Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  .section-h2 {
    font-family: 'Instrument Serif', serif;
    font-size: 38px;
    line-height: 1.1;
    font-weight: 400;
    max-width: 700px;
    margin-bottom: 56px;
  }

  /* ─── FEATURES ─── */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
  }

  .feature-cell {
    padding: 32px;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 150ms;
    cursor: default;
  }

  .feature-cell:hover { background: var(--bg-raised); }

  .feature-cell.full { grid-column: 1 / -1; }

  .feature-num {
    font-family: 'Fragment Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .feature-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .feature-body {
    font-size: 14px;
    color: var(--muted-light);
    line-height: 1.65;
  }

  /* ─── HOW IT WORKS ─── */
  .hiw-intro {
    font-size: 16px;
    color: var(--muted-light);
    max-width: 560px;
    margin-bottom: 56px;
    margin-top: 0;
  }

  .hiw-video {
    border: 1px solid var(--border);
    background: var(--bg-raised);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 56px;
    max-width: 900px;
  }

  .hiw-video video {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Hide download button from video controls */
  .hiw-video video::-internal-media-controls-download-button {
    display: none;
  }

  .hiw-video video::-webkit-media-controls-enclosure {
    overflow: hidden;
  }

  .hiw-video video::-webkit-media-controls-panel {
    width: calc(100% - 30px);
  }

  .timeline {
    position: relative;
    padding-left: 80px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 28px;
    top: 12px;
    bottom: 12px;
    width: 1px;
    background: var(--border);
  }

  .timeline-step {
    position: relative;
    margin-bottom: 40px;
  }

  .timeline-step:last-child { margin-bottom: 0; }

  .step-num {
    position: absolute;
    left: -80px;
    top: 2px;
    font-family: 'Fragment Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    background: var(--mono-bg);
    padding: 3px 7px;
    border: 1px solid var(--border);
    width: 52px;
    text-align: center;
  }

  .step-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }

  .step-body {
    font-size: 14px;
    color: var(--muted-light);
    max-width: 600px;
  }

  .timeline-break {
    margin: 40px 0;
    display: flex;
    align-items: center;
    gap: 16px;
    color: var(--muted);
    font-style: italic;
    font-size: 13px;
  }

  .timeline-break::before, .timeline-break::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .timeline-note {
    margin-top: 48px;
    font-style: italic;
    font-size: 13px;
    color: var(--muted);
    padding-left: 80px;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }

  /* ─── PRICING ─── */
  .pricing-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pricing-card {
    border: 1px solid var(--border);
    background: var(--bg-raised);
    padding: 44px;
    max-width: 520px;
    width: 100%;
  }

  .pricing-h2 {
    font-family: 'Instrument Serif', serif;
    font-size: 38px;
    font-weight: 400;
    margin-bottom: 12px;
  }

  .pricing-h2 .price-amt {
    color: var(--accent);
  }

  .pricing-sub {
    font-size: 15px;
    color: var(--muted-light);
    margin-bottom: 28px;
  }

  .pricing-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 24px 0;
  }

  .pricing-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
  }

  .pricing-list li {
    display: flex;
    gap: 12px;
    font-size: 14px;
    color: var(--text);
  }

  .pricing-list .arrow {
    font-family: 'Fragment Mono', monospace;
    color: var(--accent);
    flex-shrink: 0;
  }

  .btn-primary-full {
    width: 100%;
    background: var(--accent);
    color: var(--bg);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    padding: 14px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    display: block;
    transition: background 150ms;
  }

  .btn-primary-full:hover { background: #b8952f; }

  .pricing-early-access {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .pricing-note {
    font-size: 12px;
    color: var(--muted);
    text-align: center;
    margin-top: 16px;
    line-height: 1.6;
  }

  /* Not on Linux */
  .waitlist {
    margin-top: 64px;
    text-align: center;
    max-width: 400px;
    width: 100%;
  }

  .waitlist h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .waitlist p {
    font-size: 14px;
    color: var(--muted-light);
    margin-bottom: 20px;
  }

  .email-row {
    display: flex;
    gap: 0;
    border: 1px solid var(--border);
  }

  .email-row input {
    flex: 1;
    background: var(--bg);
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    padding: 11px 16px;
  }

  .email-row input::placeholder { color: var(--muted); }

  .email-row button {
    background: transparent;
    border: none;
    border-left: 1px solid var(--border);
    color: var(--muted-light);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 11px 20px;
    cursor: pointer;
    transition: color 150ms;
    white-space: nowrap;
  }

  .email-row button:hover { color: var(--text); }

  /* ─── FAQ ─── */
  .faq-list {
    max-width: 720px;
  }

  .faq-item {
    border-top: 1px solid var(--border);
  }

  .faq-item:last-child { border-bottom: 1px solid var(--border); }

  .faq-trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 20px 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    cursor: pointer;
    text-align: left;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.4;
  }

  .faq-toggle {
    font-family: 'Fragment Mono', monospace;
    color: var(--muted);
    font-size: 16px;
    flex-shrink: 0;
    transition: color 150ms;
    line-height: 1.4;
  }

  .faq-item.open .faq-toggle { color: var(--accent); }

  .faq-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 220ms ease, padding 220ms ease;
  }

  .faq-body-inner {
    padding-bottom: 20px;
    font-size: 14px;
    color: var(--muted-light);
    line-height: 1.7;
    max-width: 640px;
  }

  .faq-item.open .faq-body { max-height: 600px; }

  /* ─── FOOTER ─── */
  footer {
    border-top: 1px solid var(--border);
    padding: 48px 0;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
  }

  .footer-brand .wordmark {
    font-family: 'Fragment Mono', monospace;
    font-size: 13px;
    color: var(--text);
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 6px;
  }

  .footer-brand .tagline {
    font-size: 13px;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    gap: 0;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    padding: 2px 12px;
    transition: color 150ms;
  }

  .footer-links a:hover { color: var(--text); }

  .footer-links .sep {
    color: var(--border);
    font-family: 'Fragment Mono', monospace;
    font-size: 10px;
    user-select: none;
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-platform {
    font-family: 'Fragment Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }

  .footer-copy {
    font-size: 12px;
    color: var(--muted);
  }

  /* ─── FADE-UP ON SCROLL ─── */
  .reveal {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 450ms ease, transform 450ms ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    #hero {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 64px 24px;
    }

    .pipeline-graphic { display: none; }

    .hero-h1 { font-size: 44px; }

    .features-grid { grid-template-columns: 1fr; }

    .feature-cell.full { grid-column: 1; }
  }

  @media (max-width: 640px) {
    .container { padding: 0 20px; }

    .nav-links { display: none; }

    .nav-inner { padding: 0 20px; }

    .footer-top { flex-direction: column; gap: 24px; }

    .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }

    .section-h2 { font-size: 28px; }

    .pricing-card { padding: 28px 24px; }

    .timeline { padding-left: 60px; }

    .timeline::before { left: 20px; }

    .step-num { left: -60px; width: 42px; font-size: 10px; }

    .timeline-note { padding-left: 60px; }

    .hiw-video { max-width: 100%; }
  }
</style>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="nav-logo">WAZEAR</a>
    <ul class="nav-links">
      <li><a href="#features">Features</a></li>
      <li><span class="sep">·</span></li>
      <li><a href="#how-it-works">How It Works</a></li>
      <li><span class="sep">·</span></li>
      <li><a href="#pricing">Pricing</a></li>
      <li><span class="sep">·</span></li>
      <li><a href="#faq">FAQ</a></li>
      <li><span class="sep">·</span></li>
      <li><a href="/docs">Docs</a></li>
      <li><span class="sep">·</span></li>
      <li><a href="#pricing" class="nav-cta">Get Wazear</a></li>
    </ul>
  </div>
</nav>

<!-- HERO -->
<div id="hero">
  <div class="hero-text">
    <p class="hero-label mono">// AI agent orchestrator</p>
    <h1 class="hero-h1 serif">AI that checks<br>its own work.</h1>
    <p class="hero-sub">Wazear orchestrates AI agents in a structured pipeline. One builds. Another tears it apart. You get what survives.</p>
    <p class="hero-price">
      <span class="price-tag mono">Pay once</span>. Free updates on same version. Pay again only when we earn it and you find it's worth it.
    </p>
    <p class="hero-early-access mono reveal">
      Early Access version available on Linux and Windows. Contact Us for MacOS version.
    </p>
    <div class="hero-actions">
      <a href="#pricing" class="btn-primary">Get Wazear</a>
      <p class="hero-meta mono">
        Linux and Windows available · MacOS coming soon<br>
        Requires Node.js + Qwen Code (free tier: 1,000 req/day)<br>
        Or bring your own API key (OpenAI, Gemini, OpenRouter)
      </p>
    </div>
  </div>

  <!-- PIPELINE GRAPHIC -->
  <div class="pipeline-graphic">
    <svg class="pipeline-svg" viewBox="0 0 280 520" fill="none" xmlns="http://www.w3.org/2000/svg">

      <!-- Main vertical connector (animated pulse) -->
      <line class="pulse-line" x1="60" y1="30" x2="60" y2="490" style="animation-delay:1.3s"/>

      <!-- Main flow connectors -->
      <line class="connector" x1="60" y1="48" x2="60" y2="108" style="animation-delay:0.1s"/>
      <line class="connector" x1="60" y1="160" x2="60" y2="220" style="animation-delay:0.3s"/>
      <line class="connector" x1="60" y1="272" x2="60" y2="332" style="animation-delay:0.5s"/>
      <line class="connector" x1="60" y1="384" x2="60" y2="420" style="animation-delay:0.7s"/>
      <line class="connector" x1="60" y1="448" x2="60" y2="484" style="animation-delay:0.9s"/>

      <!-- Reviewer branch connectors -->
      <path class="connector-review" d="M 60 80 Q 120 80 120 134" style="animation-delay:0.2s"/>
      <path class="connector-review" d="M 60 192 Q 120 192 120 246" style="animation-delay:0.4s"/>
      <path class="connector-review" d="M 60 304 Q 120 304 120 358" style="animation-delay:0.6s"/>

      <!-- NODE: Planner -->
      <rect class="node-rect" x="10" y="12" width="100" height="36" rx="1"/>
      <text class="node-label" x="60" y="30" text-anchor="middle">PLANNER</text>

      <!-- NODE: Planner Reviewer -->
      <rect class="node-rect" x="110" y="118" width="140" height="36" rx="1" style="stroke: #2a2a26;"/>
      <text class="node-label reviewer" x="180" y="136" text-anchor="middle">PLANNER REVIEWER</text>

      <!-- NODE: Architect -->
      <rect class="node-rect" x="10" y="124" width="100" height="36" rx="1"/>
      <text class="node-label" x="60" y="142" text-anchor="middle">ARCHITECT</text>

