---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AstroError } from 'astro/errors';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const sortedDocs = docs.sort((a, b) => a.data.order - b.data.order);
  
  return sortedDocs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { title } = doc.data;
const { Content } = await render(doc);

const docs = await getCollection('docs');
const sortedDocs = docs
  .filter((doc) => !doc.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={title} canonical={`https://wazear.space/docs/${doc.id}`}>
  <style>
    :root {
      --bg:          #0d0d0c;
      --bg-raised:   #131312;
      --bg-hover:     #191917;
      --border:      #232320;
      --text:        #e4e4dc;
      --muted:       #62625c;
      --muted-light: #8a8a82;
      --accent:      #c8a847;
      --accent-dim:  #7a6525;
      --mono-bg:     #1c1c1a;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    /* Grain overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.022;
      pointer-events: none;
      z-index: 9999;
    }

    .mono { font-family: 'Fragment Mono', monospace; }
    .serif { font-family: 'Instrument Serif', serif; }

    .container {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 32px;
    }

    /* ─── NAV ─── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(13, 13, 12, 0.96);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 32px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
    }

    .nav-logo {
      font-family: 'Fragment Mono', monospace;
      font-size: 14px;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 0.08em;
      flex-shrink: 0;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0;
      list-style: none;
    }

    .nav-links li { display: flex; align-items: center; }

    .nav-links a {
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      padding: 4px 16px;
      transition: color 150ms;
    }

    .nav-links a:hover { color: var(--text); }

    .nav-links .sep {
      color: var(--border);
      font-family: 'Fragment Mono', monospace;
      font-size: 11px;
      user-select: none;
    }

    .nav-cta {
      background: var(--accent);
      color: var(--bg) !important;
      font-weight: 500;
      padding: 7px 18px !important;
      border-radius: 2px;
      font-size: 13px !important;
      transition: background 150ms !important;
      flex-shrink: 0;
    }

    .nav-cta:hover { background: var(--accent-dim) !important; color: var(--text) !important; }

    /* ─── DOCS LAYOUT ─── */
    .docs-wrapper {
      display: flex;
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 32px;
      min-height: calc(100vh - 56px);
    }

    /* ─── SIDEBAR ─── */
    .docs-sidebar {
      width: 220px;
      flex-shrink: 0;
      padding: 40px 0;
      border-right: 1px solid var(--border);
      position: sticky;
      top: 72px;
      height: calc(100vh - 72px);
      overflow-y: auto;
    }

    .docs-sidebar-title {
      font-family: 'Fragment Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.04em;
      margin-bottom: 16px;
    }

    .docs-sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .docs-sidebar-nav a {
      font-size: 14px;
      color: var(--muted-light);
      text-decoration: none;
      display: block;
      padding: 6px 0;
      transition: color 150ms;
    }

    .docs-sidebar-nav a:hover {
      color: var(--text);
    }

    .docs-sidebar-nav a.active {
      color: var(--accent);
    }

    /* ─── DOCS CONTENT ─── */
    .docs-content {
      flex: 1;
      padding: 40px 0 80px 40px;
      max-width: 700px;
    }

    .docs-content h1 {
      font-family: 'Instrument Serif', serif;
      font-size: 38px;
      font-weight: 400;
      margin-bottom: 24px;
    }

    /* ─── PROSE STYLES (GLOBAL - for markdown content) ─── */
    :global(.docs-prose) {
      font-size: 15px;
      line-height: 1.7;
    }

    :global(.docs-prose h1) {
      font-family: 'Instrument Serif', serif;
      font-size: 38px;
      font-weight: 400;
      margin-bottom: 24px;
      margin-top: 0;
    }

    :global(.docs-prose h2) {
      font-family: 'Instrument Serif', serif;
      font-size: 26px;
      font-weight: 400;
      margin-top: 40px;
      margin-bottom: 16px;
    }

    :global(.docs-prose h3) {
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      font-weight: 600;
      margin-top: 28px;
      margin-bottom: 12px;
    }

    :global(.docs-prose h4) {
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 600;
      margin-top: 24px;
      margin-bottom: 10px;
    }

    :global(.docs-prose p) {
      margin-top: 16px;
      margin-bottom: 0;
      color: var(--muted-light);
    }

    :global(.docs-prose a) {
      color: var(--accent);
      text-decoration: none;
    }

    :global(.docs-prose a:hover) {
      text-decoration: underline;
    }

    :global(.docs-prose strong) {
      font-weight: 600;
      color: var(--text);
    }

    :global(.docs-prose em) {
      font-style: italic;
      color: var(--text);
    }

    :global(.docs-prose code) {
      font-family: 'Fragment Mono', monospace;
      font-size: 13px;
      background: var(--mono-bg);
      padding: 2px 6px;
      color: var(--accent);
      border-radius: 2px;
    }

    :global(.docs-prose pre) {
      background: var(--mono-bg);
      border: 1px solid var(--border);
      padding: 20px;
      overflow-x: auto;
      margin-top: 20px;
      margin-bottom: 0;
      border-radius: 2px;
    }

    :global(.docs-prose pre code) {
      background: transparent;
      padding: 0;
      color: var(--text);
    }

    :global(.docs-prose ul),
    :global(.docs-prose ol) {
      margin-top: 16px;
      margin-bottom: 16px;
      padding-left: 24px;
      color: var(--muted-light);
      list-style-type: disc;
    }

    :global(.docs-prose ol) {
      list-style-type: decimal;
    }

    :global(.docs-prose li) {
      margin-bottom: 8px;
    }

    :global(.docs-prose blockquote) {
      border-left: 2px solid var(--accent);
      padding-left: 16px;
      margin: 20px 0;
      color: var(--muted-light);
      font-style: italic;
    }

    :global(.docs-prose hr) {
      border: none;
      border-top: 1px solid var(--border);
      margin: 32px 0;
    }

    /* ─── MOBILE TOGGLE ─── */
    .mobile-toggle {
      display: none;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted-light);
      font-family: 'Fragment Mono', monospace;
      font-size: 13px;
      padding: 8px 12px;
      cursor: pointer;
      margin-bottom: 20px;
      transition: color 150ms, border-color 150ms;
    }

    .mobile-toggle:hover {
      color: var(--text);
      border-color: var(--muted);
    }

    /* ─── FOOTER ─── */
    footer {
      border-top: 1px solid var(--border);
      padding: 48px 0;
    }

    .footer-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 32px;
    }

    .footer-brand .wordmark {
      font-family: 'Fragment Mono', monospace;
      font-size: 13px;
      color: var(--text);
      letter-spacing: 0.08em;
      display: block;
      margin-bottom: 6px;
    }

    .footer-brand .tagline {
      font-size: 13px;
      color: var(--muted);
    }

    .footer-links {
      display: flex;
      gap: 0;
      align-items: center;
      flex-wrap: wrap;
    }

    .footer-links a {
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      padding: 2px 12px;
      transition: color 150ms;
    }

    .footer-links a:hover { color: var(--text); }

    .footer-links .sep {
      color: var(--border);
      font-family: 'Fragment Mono', monospace;
      font-size: 10px;
      user-select: none;
    }

    .footer-bottom {
      border-top: 1px solid var(--border);
      padding-top: 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-platform {
      font-family: 'Fragment Mono', monospace;
      font-size: 11px;
      color: var(--muted);
    }

    .footer-copy {
      font-size: 12px;
      color: var(--muted);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .container { padding: 0 20px; }

      .nav-links { display: none; }

      .nav-inner { padding: 0 20px; }

      .docs-wrapper {
        padding: 0 20px;
      }

      .docs-sidebar {
        display: none;
        position: fixed;
        top: 56px;
        left: 0;
        width: 220px;
        height: calc(100vh - 56px);
        background: var(--bg);
        z-index: 99;
        padding: 24px;
        border-right: 1px solid var(--border);
      }

      .docs-sidebar.open {
        display: block;
      }

      .docs-content {
        padding: 20px 0 60px 0;
        width: 100%;
      }

      .mobile-toggle {
        display: block;
      }

      .footer-top { flex-direction: column; gap: 24px; }

      .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">WAZEAR</a>
      <ul class="nav-links">
        <li><a href="/#features">Features</a></li>
        <li><span class="sep">·</span></li>
        <li><a href="/#how-it-works">How It Works</a></li>
        <li><span class="sep">·</span></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><span class="sep">·</span></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><span class="sep">·</span></li>
        <li><a href="/docs">Docs</a></li>
        <li><span class="sep">·</span></li>
        <li><a href="/#pricing" class="nav-cta">Get Wazear — $49</a></li>
      </ul>
    </div>
  </nav>

  <div class="docs-wrapper">
    <!-- SIDEBAR -->
    <aside class="docs-sidebar" id="docsSidebar">
      <p class="docs-sidebar-title mono">DOCS</p>
      <nav class="docs-sidebar-nav">
        {sortedDocs.map((d) => (
          <a 
            href={`/docs/${d.id}`}
            class={d.id === doc.id ? 'active' : ''}
          >
            {d.data.title}
          </a>
        ))}
      </nav>
    </aside>

    <!-- CONTENT -->
    <main class="docs-content">
      <button class="mobile-toggle mono" id="mobileToggle" aria-label="Toggle menu">☰ Menu</button>
      <h1 class="serif">{title}</h1>
      <article class="docs-prose">
        <Content />
      </article>
    </main>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <span class="wordmark mono">WAZEAR</span>
          <span class="tagline">AI agent orchestration for builders.</span>
        </div>
        <nav class="footer-links">
          <a href="#">Download</a>
          <span class="sep">·</span>
          <a href="/docs/welcome">Docs</a>
          <span class="sep">·</span>
          <a href="/contact">Contact</a>
          <span class="sep">·</span>
          <a href="/#faq">FAQ</a>
          <span class="sep">·</span>
          <a href="#">Privacy Policy</a>
        </nav>
      </div>
      <div class="footer-bottom">
        <span class="footer-platform mono">Linux and Windows available · MacOS coming soon</span>
        <span class="footer-copy">© 2026 Wazear. All rights reserved.</span>
      </div>
    </div>
  </footer>

  <script>
    // Mobile sidebar toggle
    const toggle = document.getElementById('mobileToggle');
    const sidebar = document.getElementById('docsSidebar');
    
    toggle?.addEventListener('click', () => {
      sidebar?.classList.toggle('open');
    });

    // Close sidebar when clicking outside on mobile
    document.addEventListener('click', (e) => {
      if (window.innerWidth <= 768) {
        if (!sidebar?.contains(e.target) && !toggle?.contains(e.target)) {
          sidebar?.classList.remove('open');
        }
      }
    });
  </script>
</BaseLayout>
